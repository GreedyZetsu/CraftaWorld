-- Farm bounds
local FARM_ITEM_NAME = getgenv().Blocks
local FARM_START_X   = 0
local FARM_END_X     = 100
local FARM_X_STEP    = 5       -- move 5 tiles per anchor
local FARM_Y_STEP    = 6       -- y rows: 7, 13, 19, 25... (pairs: 6+8, 12+14, 18+20...)
local FARM_Y_ABOVE   = 1       -- place at anchorY + 1
local FARM_Y_BELOW   = -1      -- place at anchorY - 1

-- Scan bounds
local SCAN_Y_START = 6
local SCAN_Y_END   = 60
local SCAN_Y_STEP  = 2         -- check y6, y8, y10 ... y60

-- Tiles to IGNORE during scan (won't trigger dirty or block farming)
local ScanIgnore = {
    ["Dirt Background"] = true,
    ["Main Door"]       = true,
    ["MainDoor"]        = true,
    ["Bedrock"]         = true,
    ["Wooden Frame"]    = true,
    ["World Lock"]      = true,
	["Large Lock"] = true,
	["Medium Lock"] = true,
	["Small Lock"] = true,
	["Lock Area"] = true,
	["Wooden Door"] = true
}

-- Tiles to NOT punch during clear
local PunchBlacklist = {
    ["Bedrock"]         = true,
    ["Main Door"]       = true,
    ["MainDoor"]        = true,
    ["Wooden Frame"]    = true,
    ["World Lock"]      = true,
	["Large Lock"] = true,
	["Medium Lock"] = true,
	["Small Lock"] = true,
	["Lock Area"] = true,
	["Wooden Door"] = true
}

-- Tiles that count as "filled" for farm row skip check
local FarmFilled = {
    ["Wooden Frame"]    = true,
    ["World Lock"]      = true,
    ["Bedrock"]         = true,
	["Large Lock"] = true,
	["Medium Lock"] = true,
	["Small Lock"] = true,
	["Lock Area"] = true,
	["Wooden Door"] = true
}

