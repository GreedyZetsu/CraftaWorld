local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local uis = game:GetService("UserInputService")

-- Managers & Modules
local WorldTilesData = require(ReplicatedStorage:WaitForChild("WorldTiles"))
local ItemsManager = require(ReplicatedStorage.Managers.ItemsManager)
local WorldManager = require(ReplicatedStorage:WaitForChild("Managers"):WaitForChild("WorldManager"))
local movement = require(Players.LocalPlayer.PlayerScripts.PlayerMovement)

-- [[ INITIAL CONFIG ]] --
local TILE_SIZE = 4.5

local settings = {
    Enabled = true,
    StepInterval = 0.06,
    AutoPathing = false,
    AutoPunch = true,
    CurrentStatus = "Idle"
}

-- Blocks that get fully cleared when in path
local AllowedBlocks = {
    ["Dirt"] = true,
    ["Dirt Background"] = true,
    ["Stone"] = true,
    ["Magma"] = true,
    ["Obsidian"] = true,
    ["Granite"] = true
}

-- Magma only at offset +1 and -1 (side tiles)
local MagmaOnlyOffsets = { 1, -1 }

--------------------------------------------------------------------------------
-- DRAGGABLE
--------------------------------------------------------------------------------
local function makeDraggable(frame)
    local dragging, dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    uis.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

--------------------------------------------------------------------------------
-- GRID HELPERS
--------------------------------------------------------------------------------
local function getCurrentGrid()
    local curX = math.round(movement.Position.X / TILE_SIZE)
    local curY = math.round(movement.Position.Y / TILE_SIZE)
    return curX, curY
end

local function getTileSlotName(gx, gy, slot)
    local data = WorldTilesData[gx] and WorldTilesData[gx][gy]
    if data and data[slot] then
        local itemId = (type(data[slot]) == "table") and data[slot][1] or data[slot]
        local baseData = ItemsManager.RequestItemData(tostring(itemId))
        return baseData and baseData.Name or "Unknown"
    end
    return "None"
end

-- Live detection via WorldManager
local function isTargetOccupied(gx, gy)
    return WorldManager.GetTile(gx, gy, 1) ~= nil or WorldManager.GetTile(gx, gy, 2) ~= nil
end

local function getTileName(gx, gy)
    local id = WorldManager.GetTile(gx, gy, 1) or WorldManager.GetTile(gx, gy, 2)
    if not id then return nil end
    local ok, name = pcall(function() return ItemsManager.GetName(id) end)
    return ok and name or nil
end

local function isMagma(gx, gy)
    local name = getTileName(gx, gy)
    return name == "Magma"
end

--------------------------------------------------------------------------------
-- CLEAR LOGIC
--------------------------------------------------------------------------------
local function waitUntilClear(gx, gy, timeout)
    timeout = timeout or 5.0
    local fistRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("PlayerFist")
    local startTime = tick()

    while settings.AutoPathing do
        if (tick() - startTime) >= timeout then
            warn(string.format("[AutoPath] Timeout clearing (%d, %d) — skipping", gx, gy))
            break
        end
        local hasFG = WorldManager.GetTile(gx, gy, 1)
        local hasBG = WorldManager.GetTile(gx, gy, 2)
        if not hasFG and not hasBG then break end
        fistRemote:FireServer(Vector2.new(gx, gy))
        task.wait(0.05)
    end
end

local function clearCoordinate(gx, gy)
    local hasFG = WorldManager.GetTile(gx, gy, 1)
    local hasBG = WorldManager.GetTile(gx, gy, 2)
    if not hasFG and not hasBG then return end
    waitUntilClear(gx, gy, 5.0)
end

local function clearStackAtX(gx, gy)
    -- offset +2 and -2: full AllowedBlocks clear
    for _, offset in ipairs({2, -2}) do
        if isTargetOccupied(gx, gy + offset) then
            clearCoordinate(gx, gy + offset)
            task.wait(0.05)
        end
    end

    -- center tile: full AllowedBlocks clear
    if isTargetOccupied(gx, gy) then
        clearCoordinate(gx, gy)
        task.wait(0.05)
    end

    -- offset +1 and -1: ONLY punch if it's Magma
    for _, offset in ipairs(MagmaOnlyOffsets) do
        if isMagma(gx, gy + offset) then
            clearCoordinate(gx, gy + offset)
            task.wait(0.05)
        end
    end

    -- Verification re-pass (all 5 offsets)
    local retryLimit = 3
    for attempt = 1, retryLimit do
        local allClear = true

        -- Full clear check for +2, 0, -2
        for _, offset in ipairs({2, 0, -2}) do
            if isTargetOccupied(gx, gy + offset) then
                allClear = false
                warn(string.format("[clearStack] Re-clearing (%d, %d) attempt %d", gx, gy + offset, attempt))
                clearCoordinate(gx, gy + offset)
                task.wait(0.05)
            end
        end

        -- Magma-only check for +1 and -1
        for _, offset in ipairs(MagmaOnlyOffsets) do
            if isMagma(gx, gy + offset) then
                allClear = false
                warn(string.format("[clearStack] Re-clearing Magma (%d, %d) attempt %d", gx, gy + offset, attempt))
                clearCoordinate(gx, gy + offset)
                task.wait(0.05)
            end
        end

        if allClear then break end
        task.wait(0.1)
    end
end

--------------------------------------------------------------------------------
-- POSITION LOCK
--------------------------------------------------------------------------------
local lockedPosition = nil

local function snapToGrid(pos)
    local gx = math.round(pos.X / TILE_SIZE)
    local gy = math.round(pos.Y / TILE_SIZE)
    return Vector3.new(gx * TILE_SIZE, gy * TILE_SIZE, 0)
end

RunService.RenderStepped:Connect(function()
    if settings.AutoPathing and lockedPosition then
        movement.Position = lockedPosition
        movement.OldPosition = lockedPosition
        movement.VelocityX = 0
        movement.VelocityY = 0
        movement.MoveX = 0
    end
end)

--------------------------------------------------------------------------------
-- GRID MOVEMENT
--------------------------------------------------------------------------------
local function gridMoveTo(targetX, targetY)
    local moveRemote = ReplicatedStorage:FindFirstChild("Hsyauzn", true)

    while settings.AutoPathing do
        local curX, curY = getCurrentGrid()
        if curX == targetX and curY == targetY then
            lockedPosition = Vector3.new(targetX * TILE_SIZE, targetY * TILE_SIZE, 0)
            movement.Position = lockedPosition
            movement.OldPosition = lockedPosition
            movement.VelocityX, movement.VelocityY = 0, 0
            break
        end

        local nextX = curX + (targetX > curX and 1 or (targetX < curX and -1 or 0))
        local nextY = curY + (targetY > curY and 1 or (targetY < curY and -1 or 0))

        if isTargetOccupied(nextX, nextY) then
            clearCoordinate(nextX, nextY)
        end

        lockedPosition = Vector3.new(nextX * TILE_SIZE, nextY * TILE_SIZE, 0)
        movement.Position = lockedPosition
        movement.OldPosition = lockedPosition
        movement.VelocityX, movement.VelocityY = 0, 0

        if moveRemote then
            moveRemote:FireServer({ Vector2.new(lockedPosition.X, lockedPosition.Y) })
        end

        task.wait(settings.StepInterval)
    end

    if not settings.AutoPathing then
        lockedPosition = nil
    end
end

local function clearWidthAtY(gx1, gx2, gy)
    clearCoordinate(gx1, gy)
    clearCoordinate(gx2, gy)
end

--------------------------------------------------------------------------------
-- AUTOMATION ROUTINE
--------------------------------------------------------------------------------
local ToggleBtn -- forward declare so runAutomation can reference it

local function runAutomation()
    settings.CurrentStatus = "Initializing..."
    local hurtMeRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("PlayerHurtMe")
    hurtMeRemote:FireServer(100)
    task.wait(1)

    -- Phase 1: Left Columns
    settings.CurrentStatus = "To 0,37"
    gridMoveTo(0, 37)

    settings.CurrentStatus = "Clearing 0 & 1"
    for y = 37, 6, -1 do
        if not settings.AutoPathing then break end
        clearWidthAtY(0, 1, y)
        gridMoveTo(0, y)
    end

    -- Phase 2: Cross Map
    settings.CurrentStatus = "Returning to Top"
    gridMoveTo(0, 37)
    settings.CurrentStatus = "Crossing Map"
    gridMoveTo(100, 37)

    -- Phase 3: Right Columns
    settings.CurrentStatus = "Clearing 99 & 100"
    for y = 37, 6, -1 do
        if not settings.AutoPathing then break end
        clearWidthAtY(99, 100, y)
        gridMoveTo(100, y)
    end

    -- Phase 4: Snake
    settings.CurrentStatus = "Reposition to 100,9"
    gridMoveTo(100, 9)

    local currentY = 9
    local iteration = 0

    while settings.AutoPathing do
        if currentY > 60 then break end

        local isMovingLeft = (iteration % 2 == 0)
        local xStart = isMovingLeft and 100 or 0
        local xEnd = isMovingLeft and 0 or 100
        local step = isMovingLeft and -1 or 1

        settings.CurrentStatus = "Snake Y:" .. currentY

        gridMoveTo(xStart, currentY)
        for x = xStart, xEnd, step do
            if not settings.AutoPathing then break end
            clearStackAtX(x, currentY)
            gridMoveTo(x, currentY)
        end

        if currentY == 9 then
            currentY = 15
        else
            currentY = currentY + 6
        end
        iteration = iteration + 1
    end

    settings.AutoPathing = false
    lockedPosition = nil
    settings.CurrentStatus = "Idle"
    ToggleBtn.Text = "▶ START"
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 80)
end

